# Codveda Technologies - Data Scraper Web Application
# Environment Variables Configuration
# Copy this file to .env and modify as needed

# =============================================================================
# Application Settings
# =============================================================================
# Debug mode (True/False)
DEBUG=False

# =============================================================================
# Scraping Settings
# =============================================================================
# Request timeout in seconds
DEFAULT_TIMEOUT=30

# Maximum number of results to extract per scrape
MAX_RESULTS=50

# Minimum interval between requests (rate limiting)
RATE_LIMIT_INTERVAL=1.0

# Maximum pages to scrape (for pagination support)
MAX_PAGES=5

# =============================================================================
# Logging Settings
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# UI Settings
# =============================================================================
# Show advanced options by default (True/False)
SHOW_ADVANCED_BY_DEFAULT=False

# Maximum history entries to keep
HISTORY_LIMIT=50
