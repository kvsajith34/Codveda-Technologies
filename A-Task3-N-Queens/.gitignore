# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.coveragerc

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Streamlit
.streamlit/secrets.toml

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Jupyter notebooks (if any)
.ipynb_checkpoints/
*.ipynb

# Logs
*.log
logs/

# Environment variable files
.env
.env.local
.env.production
